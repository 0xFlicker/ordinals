{
  "name": "@0xflick/ordinals-schrodingers-cat",
  "version": "0.0.1",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "build:script": "esbuild --watch=forever --alias:inscriptions/index.js=./tmp/inscriptions.js --bundle --platform=browser --target=es2022 --outfile=content/script.js --tree-shaking=true ./src/ordinal.ts",
    "server": "node --loader ts-node/esm ./src/server.ts",
    "dev": "npm run build:script & npm run server"
  },
  "devDependencies": {
    "typescript": "^5.1.3"
  },
  "dependencies": {
    "hono": "^4.1.2"
  }
}